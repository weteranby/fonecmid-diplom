#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// +++
	// ВКМ Супонев - Дипломный проект
	//
	// Заполнение списка выбора времени - Кратность 1 час
		
	ЗаполнитьВыпадающийСписокНачала();
	
	Если ЗначениеЗаполнено(Объект.ВремяНачалаРабот) Тогда
		ЗаполнитьВыпадающийСписокОкончания();
	КонецЕсли;
	
	// Отображение только Специалистов на форме

	СписокСпецов = ПолучитьСписокСпециалистовНаСервере();

	НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", СписокСпецов);
	
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(НовыйПараметр);

	Элементы.Специалист.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
		
	// ВКМ Супонев - Дипломный проект
	// +++
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
    // СтандартныеПодсистемы.ПодключаемыеКоманды
    ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
    // Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// +++
	// ВКМ Супонев - Дипломный проект
	// Обращение к видимости реквизитовв при Абонентском Обслуживании
	
	ВКМ_ОбновитьПоказателиДоговораНаСервере();
	
	// ВКМ Супонев - Дипломный проект
	// +++
КонецПроцедуры



